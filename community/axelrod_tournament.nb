Cell["\<\
Greedy discovery: best field score found so far, starting from Tit-for-Tat, \
at two noise levels. Each upward step is an accepted proposal.\
\>", "Text",
 CellMargins->{{70, 70}, {2, 14}},
 FontSize->11,
 FontSlant->Italic,
 FontColor->GrayLevel[
  0.35],ExpressionUUID->"1948766d-f828-4d4c-90ec-6730fddc3d20"],

Cell[CellGroupData[{

